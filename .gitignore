tokens.json
ledger.json
*.tmp

# Machine-specific local notes / overrides (deployment runbooks, etc.) — never committed
*.local
*.local.*

# Backups / dumps
backups/
*.bak
*.sql

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
.idea/
