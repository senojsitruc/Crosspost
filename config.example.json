{
  "port": 3737,
  "host": "127.0.0.1",
  "ghostWebhookSecret": "REPLACE_WITH_A_50+_CHAR_RANDOM_STRING",
  "signatureToleranceMs": 300000,
  "maxBackdateMs": 21600000,
  "dryRun": true,
  "siteUrl": "https://example.com",
  "landing": {
    "appName": "Crosspost",
    "tagline": "Automatic Pinterest cross-posting for my blog",
    "description": "Crosspost is a personal automation tool that publishes new posts from my blog to my own Pinterest board. It is built for my blog alone and does not post on anyone else's behalf."
  },
  "targets": {
    "x": true,
    "reddit": true,
    "facebook": true,
    "pinterest": true
  },
  "x": {
    "consumerKey": "REPLACE_WITH_API_KEY",
    "consumerSecret": "REPLACE_WITH_API_SECRET_KEY",
    "accessToken": "REPLACE_WITH_ACCESS_TOKEN",
    "accessTokenSecret": "REPLACE_WITH_ACCESS_TOKEN_SECRET"
  },
  "reddit": {
    "clientId": "REPLACE",
    "clientSecret": "REPLACE",
    "redirectUri": "http://localhost/callback",
    "username": "your_reddit_username",
    "userAgent": "web:my-ghost-crosspost:v1.0 (by /u/your_reddit_username)"
  },
  "facebook": {
    "pageId": "REPLACE_WITH_PAGE_ID",
    "pageAccessToken": "REPLACE_WITH_NEVER_EXPIRING_PAGE_TOKEN"
  },
  "pinterest": {
    "clientId": "REPLACE_WITH_APP_ID",
    "clientSecret": "REPLACE_WITH_APP_SECRET",
    "redirectUri": "https://example.com/pinterest/callback",
    "boardId": "REPLACE_WITH_BOARD_ID",
    "fallbackImageUrl": "https://example.com/path/to/default-cover.jpg"
  }
}
